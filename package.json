{
  "name": "offerlab-vue",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "typecheck": "vue-tsc --noEmit",
    "test:permissions": "node scripts/test-admin-permissions.mjs",
    "test:error-handling": "node scripts/test-error-handling.mjs",
    "test:editor-notification-errors": "node scripts/test-editor-notification-errors.mjs",
    "test:markdown-safety": "node scripts/test-markdown-safety.mjs",
    "test:search-permissions": "node scripts/test-search-permissions.mjs",
    "test:routes": "node scripts/test-route-meta.mjs",
    "test:guards": "npm run test:permissions && npm run test:error-handling && npm run test:editor-notification-errors && npm run test:markdown-safety && npm run test:search-permissions && npm run test:routes",
    "verify": "npm run test:guards && npm run build"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.28.0",
    "@types/markdown-it": "^14.1.2",
    "@vueuse/core": "^10.7.0",
    "axios": "^1.6.0",
    "clsx": "^2.1.1",
    "echarts": "^5.4.0",
    "highlight.js": "^11.9.0",
    "lucide-vue-next": "^0.294.0",
    "markdown-it": "^14.1.1",
    "md-editor-v3": "^4.12.0",
    "pinia": "^2.1.0",
    "shadcn-vue": "^0.8.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.0",
    "vee-validate": "^4.12.0",
    "vue": "^3.4.0",
    "vue-echarts": "^6.1.0",
    "vue-router": "^4.3.0",
    "vue-sonner": "^1.1.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.55.0",
    "eslint-plugin-vue": "^9.19.0",
    "postcss": "^8.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-tsc": "^2.2.0"
  }
}
